# DDUnlimited Forum Credentials
DDU_USERNAME=your_username
DDU_PASSWORD=your_password

# Database
DATABASE_PATH=ddunlimited.db

# Pages file (path to the file containing pages to scrape)
PAGES_FILE=pages.txt

# Scraper Settings
REQUEST_DELAY=1.5
REQUEST_TIMEOUT=30

# Flask Settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=False

# Scheduler Settings (for automatic reimportation)
# SCRAPE_INTERVAL_DAYS: How many days to wait between imports (default: 3)
# SCRAPE_HOUR: Hour of the day to run import (24h format, default: 2 = 2 AM)
# SCRAPE_MINUTE: Minute of the hour to run import (default: 0)
SCRAPE_INTERVAL_DAYS=3
SCRAPE_HOUR=2
SCRAPE_MINUTE=0

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# Set to DEBUG to see every title found during Single Import
LOG_LEVEL=INFO

# Post detail scraping: visita ogni singolo post per estrarre quality, lingue, codec dall'h4/h2
# Piu' lento ma dati piu' ricchi (languages, status, codec completi)
SCRAPE_POST_DETAILS=true
# Numero di richieste parallele ai singoli post (max consigliato: 5)
POST_DETAIL_WORKERS=3
